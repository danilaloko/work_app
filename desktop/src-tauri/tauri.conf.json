{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Presence Desktop",
  "version": "0.1.0",
  "identifier": "app.presence.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Presence Desktop",
        "width": 960,
        "height": 720,
        "minWidth": 720,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Team laptop presence notifier"
  }
}
